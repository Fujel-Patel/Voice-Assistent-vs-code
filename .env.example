# ============================================================
# Jarvis Voice Assistant — Environment Variables Template
# ============================================================
# Copy this file to .env and fill in your actual values.
# The .env file is .gitignore'd and must NEVER be committed.
#
# API keys can also be stored in the OS keyring using:
#   python3 -c "import keyring; keyring.set_password('jarvis-voice-assistant', 'CLAUDE_API_KEY', 'YOUR_KEY')"
#
# Usage:
#   cp .env.example .env
#   nano .env   (add your keys)
#   bash scripts/dev.sh
# ============================================================

# ────────────────────────────────────────
# Required for Phase 2 (Claude Brain)
# Get yours at: https://console.anthropic.com/
# ────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ────────────────────────────────────────
# Required for Phase 3 (TTS Output)
# Get yours at: https://elevenlabs.io/
# ────────────────────────────────────────
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# ────────────────────────────────────────
# Required for Phase 1 (Wake Word - Porcupine)
# Get yours at: https://console.picovoice.ai/
# Free tier available!
# ────────────────────────────────────────
PORCUPINE_ACCESS_KEY=your_porcupine_access_key_here

# ────────────────────────────────────────
# Optional for Phase 7 (Web Search)
# Get yours at: https://api.search.brave.com/
# Leave blank to use DuckDuckGo (free fallback)
# ────────────────────────────────────────
BRAVE_SEARCH_API_KEY=your_brave_search_api_key_here

# ────────────────────────────────────────
# Backend server configuration
# (Optional — defaults are in config/default.yaml)
# ────────────────────────────────────────
# JARVIS_SERVER__PORT=8765
# JARVIS_VOICE__WHISPER_MODEL=small
# JARVIS_BRAIN__MODEL=claude-sonnet-4-5

# ────────────────────────────────────────
# Development flags
# ────────────────────────────────────────
NODE_ENV=development
