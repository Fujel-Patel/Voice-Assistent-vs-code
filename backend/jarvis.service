[Unit]
Description=Jarvis Voice Assistant Backend
After=network.target

[Service]
Type=simple
User=%u
WorkingDirectory=__JARVIS_BACKEND_DIR__
ExecStart=__JARVIS_PYTHON__ main.py
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal
EnvironmentFile=__JARVIS_ENV_FILE__
MemoryMax=2G
CPUQuota=50%

[Install]
WantedBy=default.target
